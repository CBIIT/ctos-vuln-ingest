# Local development credentials — copy to .env and fill in values.
# In Prefect runtime these are NOT used; secrets come from AWS Secrets Manager
# via the ARNs stored in Prefect Variables (TWISTLOCK_SECRET_ARN, DB_SECRET_ARN).

# Twistlock / Prisma Cloud Compute
TWISTLOCK_BASE_URL=https://your-twistlock-console.example.com
TWISTLOCK_USERNAME=
TWISTLOCK_PASSWORD=

# PostgreSQL connection — defaults match docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vuln_ingest
DB_USER=vuln_user
DB_PASSWORD=vuln_pass
